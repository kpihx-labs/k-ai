# Server
K_AI_HOST=0.0.0.0
K_AI_PORT=8080
K_AI_ADMIN_TOKEN=change-me-admin-token

# Paths
K_AI_CONFIG_PATH=./config/config.yaml
K_AI_DATA_DIR=./data

# Base URL for mock self-routing (native dev: matches K_AI_PORT)
K_AI_BASE_URL=http://127.0.0.1:8080

# Local providers
K_AI_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Cloud providers — run: make sync-env (reads opencode/hermes auth, never committed)
K_AI_OPENROUTER_API_KEY=
K_AI_OPENCODE_API_KEY=
K_AI_OPENCODE_GO_API_KEY=
K_AI_VENICE_API_KEY=
K_AI_MISTRAL_API_KEY=

# Production (homelab Docker): generate-prod-env.sh sets K_AI_BASE_URL=http://127.0.0.1:8080
# Traefik exposes https://ai.kpihx-labs.com externally — do NOT use public URL for mock routing.
